# Init container for K8s sidecar deployments.
# Copies the pipelock binary to a shared volume for MCP stdio wrapping.
# Used by GoReleaser — copies the pre-built (enterprise-tagged) binary. For
# an Apache-2.0-only equivalent built from source, see Dockerfile.init.apache.
#
# Usage in a pod spec:
#   initContainers:
#     - name: pipelock-init
#       image: ghcr.io/luckypipewrench/pipelock-init:latest
#       command: ["cp", "/pipelock", "/shared-bin/pipelock"]
#       volumeMounts:
#         - name: shared-bin
#           mountPath: /shared-bin
FROM alpine:3.23@sha256:5b10f432ef3da1b8d4c7eb6c487f2f5a8f096bc91145e68878dd4a5019afde11
COPY pipelock /pipelock
USER 65534
